# Supabase 环境变量配置
# 复制此文件为 .env 并填入您的 Supabase 项目凭证

# Supabase 项目 URL (从 Project Settings → API 获取)
# 格式: https://<project-ref>.supabase.co
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon public API key (从 Project Settings → API 获取)
VITE_SUPABASE_ANON_KEY=your-anon-key-here
